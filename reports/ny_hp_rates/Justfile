all: clean render

# Delete all caches
clean:
    rm -rf .quarto docs/*_files/ notebooks/*_files/ notebooks/*.html \
           notebooks/*.ipynb notebooks/*.rmarkdown \
           docs-baseline .diff prerendered_old prerendered_new

# Render quarto project (snapshots current docs/ as baseline for diffing)
render:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -d docs ]; then rm -rf docs-baseline && cp -r docs docs-baseline; fi
    uv run quarto render .
    find docs -name '*.ipynb' -delete 2>/dev/null || true

today := `date +%Y%m%d`
draft_name := "report_draft_" + today + ".docx"

draft:
    uv run quarto render index.qmd --to docx --output {{ draft_name }}

typeset_name := "report_" + today + ".icml"

typeset:
    uv run quarto render index.qmd --to icml --output {{ typeset_name }}

publish:
    bash -c 'parent_folder=$(basename $(pwd)); pub_path="../../docs/$parent_folder"; \
    rm -rf "$pub_path" && mkdir -p "$pub_path" && \
    cp -r docs/* "$pub_path/"'

# Compare current render against baseline (baseline is auto-saved by render)
diff:
    uv run python -m lib.diff_report docs-baseline docs .diff
