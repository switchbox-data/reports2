all: clean render

clean:
    uv run python -m lib.just.clean

render path_qmd="":
    uv run python -m lib.just.render {{ path_qmd }}

today := `date +%Y%m%d`

draft path_qmd="index.qmd":
    #!/usr/bin/env bash
    set -euo pipefail
    out="{{ if path_qmd == "index.qmd" { "report_draft_" + today + ".docx" } else { file_stem(path_qmd) + "_" + today + ".docx" } }}"
    if [ "{{ path_qmd }}" != "index.qmd" ] && [ -f _quarto.yml ]; then
        mv _quarto.yml _quarto.yml.draft_bak
        trap 'mv _quarto.yml.draft_bak _quarto.yml' EXIT
    fi
    # Purge cached notebook outputs so embeds re-execute with PNG settings
    rm -rf .quarto/_freeze docs/notebooks
    export SWITCHBOX_GT_AS_IMAGE=1
    uv run quarto render "{{ path_qmd }}" --to docx -M fig-dpi:300 -M fig-format:png --output "$out"

typeset path_qmd="":
    uv run python -m lib.just.typeset {{ path_qmd }}

publish:
    uv run python -m lib.just.publish

diff label="":
    uv run python -m lib.just.diff {{ label }}
