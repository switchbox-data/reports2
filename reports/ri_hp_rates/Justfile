all: clean render

clean:
    uv run python -m lib.report_clean

render:
    uv run python -m lib.report_render

draft:
    quarto render index.qmd --to docx --output report_draft.docx

typeset:
    quarto render index.qmd --to icml

publish:
    uv run python -m lib.report_publish

diff label="":
    uv run python -m lib.diff_report {{ label }}
