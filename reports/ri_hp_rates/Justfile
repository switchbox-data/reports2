all: clean render

clean:
    uv run python -m lib.just.clean

render:
    uv run python -m lib.just.render

# Expert testimony outline only (CLF / RIPUC). File is testimony_outline.qmd → docs/testimony_outline.html
expert-testimony:
    uv run quarto render testimony_outline.qmd

today := `date +%Y%m%d`
draft_name := "report_draft_" + today + ".docx"

draft:
    uv run quarto render index.qmd --to docx --output {{ draft_name }}

typeset_name := "report_" + today + ".icml"

typeset:
    uv run quarto render index.qmd --to icml --output {{ typeset_name }}

publish:
    uv run python -m lib.just.publish

diff label="":
    uv run python -m lib.just.diff {{ label }}
